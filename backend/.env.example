# ============================================
# Crystal People Lite - Backend Environment
# ============================================
# Copy this file to .env and fill in values

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Google Sheets API
# Create a service account at https://console.cloud.google.com
# Enable Google Sheets API, download JSON key
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SHEET_NAME=Reviews
GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"

# Claude AI (Anthropic)
# Get API key at https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-3-haiku-20240307
